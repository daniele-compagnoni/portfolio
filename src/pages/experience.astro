---
import Layout from '../layouts/Layout.astro';
import Card from '../components/ui/Card.astro';
import { getCollection, render } from 'astro:content';

const experience = await getCollection('experience');
experience.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---

<Layout title="Experience | Daniele Compagnoni" description="Chronological mapping of professional and significant academic roles.">
  <div class="max-w-[85ch] mx-auto py-12">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-text-primary mb-12">Experience</h1>
    
    <div class="relative border-l border-border-subtle ml-4 md:ml-6 pl-8 md:pl-12 py-4 space-y-12">
      {experience.map(async (exp) => {
        const { Content } = await render(exp);
        return (
          <div class="relative">
            <div class="absolute w-3 h-3 bg-action-primary rounded-full -left-[38px] md:-left-[54px] top-6 ring-4 ring-bg-base"></div>
            <Card class="p-6 md:p-8">
              <div class="flex flex-col md:flex-row md:justify-between md:items-start gap-4 mb-6">
                <div>
                  <h2 class="text-xl font-semibold text-text-primary mb-1">{exp.data.role}</h2>
                  <span class="text-sm font-mono text-text-secondary">{exp.data.organization}</span>
                </div>
                <time class="text-xs font-mono text-text-muted bg-bg-muted border border-border-subtle px-2 py-1 rounded-md whitespace-nowrap">
                  {new Date(exp.data.startDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' })} — 
                  {exp.data.endDate ? new Date(exp.data.endDate).toLocaleDateString('en-US', { year: 'numeric', month: 'short' }) : 'Present'}
                </time>
              </div>
              
              <div class="prose prose-zinc dark:prose-invert max-w-none prose-p:font-serif prose-p:leading-relaxed prose-li:font-serif prose-sm mb-6">
                <Content />
              </div>

              <div class="flex flex-wrap gap-2">
                {exp.data.skills.map(skill => (
                  <a href="/skills" class="inline-flex items-center rounded-md border border-action-primary/20 bg-action-primary/5 px-2 py-0.5 text-[10px] font-mono font-medium text-text-primary hover:border-action-primary/40 hover:bg-action-primary/10 transition-colors">
                    {skill.id}
                  </a>
                ))}
              </div>
            </Card>
          </div>
        )
      })}
    </div>
  </div>
</Layout>
