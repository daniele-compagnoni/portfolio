---
import Layout from '../../layouts/Layout.astro';
import ProjectFilter from '../../components/vue/ProjectFilter.vue';
import { getCollection } from 'astro:content';

const projects = await getCollection('projects');
projects.sort((a, b) => b.data.startDate.valueOf() - a.data.startDate.valueOf());
---

<Layout title="Projects | Daniele Compagnoni" description="Engineering portfolio and highly interactive hub for technical output.">
  <div class="max-w-[1200px] mx-auto py-12">
    <div class="max-w-[85ch] mb-12">
      <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-text-primary mb-6">Projects</h1>
      <p class="text-lg text-text-secondary font-serif leading-relaxed">
        A structured catalog of my engineering work. Use the filters below to query by text, technology stack, or context.
      </p>
    </div>

    <ProjectFilter client:load projects={projects} />
  </div>
</Layout>
