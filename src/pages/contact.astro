---
import Layout from '@/layouts/Layout.astro';
import Button from '@/components/ui/Button.astro';
import { Mail, Phone } from '@lucide/vue';

// Replace with your Web3Forms Access Key
const WEB3FORMS_ACCESS_KEY = "YOUR_ACCESS_KEY_HERE"; 
---

<Layout title="Contact | Daniele Compagnoni" description="Get in touch with Daniele Compagnoni.">
  <div class="max-w-[75ch] mx-auto py-12">
    <h1 class="text-4xl md:text-5xl font-semibold tracking-tight text-text-primary mb-6">Contact</h1>
    <p class="text-lg text-text-secondary font-serif leading-relaxed mb-12">
      I typically respond to inquiries within 24-48 hours. Feel free to reach out via the secure form below or connect through my professional networks.
    </p>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Form Section -->
      <div class="md:col-span-2">
        <form action="https://api.web3forms.com/submit" method="POST" class="flex flex-col gap-6">
          <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
          <input type="hidden" name="subject" value="New Contact Request from Portfolio" />
          <input type="checkbox" name="botcheck" class="hidden" style="display: none;" />

          <div class="flex flex-col gap-2">
            <label for="name" class="text-sm font-medium text-text-primary">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-2 bg-bg-elevated border border-border-subtle rounded-md text-text-primary placeholder:text-text-muted focus:outline-none focus:border-action-primary focus:ring-1 focus:ring-action-primary transition-colors" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-medium text-text-primary">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-2 bg-bg-elevated border border-border-subtle rounded-md text-text-primary placeholder:text-text-muted focus:outline-none focus:border-action-primary focus:ring-1 focus:ring-action-primary transition-colors" />
          </div>

          <div class="flex flex-col gap-2">
            <label for="message" class="text-sm font-medium text-text-primary">Message</label>
            <textarea id="message" name="message" rows="5" required class="w-full px-4 py-2 bg-bg-elevated border border-border-subtle rounded-md text-text-primary placeholder:text-text-muted focus:outline-none focus:border-action-primary focus:ring-1 focus:ring-action-primary transition-colors resize-y"></textarea>
          </div>

          <Button type="submit" variant="primary" class="w-full md:w-auto self-start">Send Message</Button>
        </form>
      </div>

      <!-- Alternative Routing -->
      <div class="flex flex-col gap-8">
        <div>
          <h3 class="text-xs font-bold text-text-muted uppercase tracking-wider mb-4">Direct Communication</h3>
          <div class="flex flex-col gap-4">
            <a href="mailto:danielecompagnoni.business@proton.me" class="inline-flex items-center gap-2 text-text-secondary hover:text-action-primary transition-colors">
              <Mail class="w-5 h-5" />
              <span class="font-mono text-sm break-all">danielecompagnoni.business<br/>@proton.me</span>
            </a>
            <a href="tel:+393270593742" class="inline-flex items-center gap-2 text-text-secondary hover:text-action-primary transition-colors">
              <Phone class="w-5 h-5" />
              <span class="font-mono text-sm">+39 3270593742</span>
            </a>
          </div>
        </div>

        <div>
          <h3 class="text-xs font-bold text-text-muted uppercase tracking-wider mb-4">Networks</h3>
          <div class="flex flex-col gap-4">
            <a href="https://github.com/daniele-compagnoni" target="_blank" class="inline-flex items-center gap-2 text-text-secondary hover:text-action-primary transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path>
                <path d="M9 18c-4.51 2-5-2-7-2"></path>
              </svg>
              <span class="font-mono text-sm">GitHub</span>
            </a>
            <a href="https://linkedin.com/in/daniele-compagnoni-5b3a502a6" target="_blank" class="inline-flex items-center gap-2 text-text-secondary hover:text-action-primary transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
                <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
                <rect width="4" height="12" x="2" y="9"></rect>
                <circle cx="4" cy="4" r="2"></circle>
              </svg>
              <span class="font-mono text-sm">LinkedIn</span>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>
