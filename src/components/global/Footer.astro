---
import { Github, Linkedin, Mail } from 'lucide-vue-next';
const currentYear = new Date().getFullYear();
---

<footer class="bg-bg-muted border-t border-border-subtle py-12 mt-24">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
    <div class="flex flex-col gap-2 text-center md:text-left">
      <span class="font-semibold text-text-primary">Daniele Compagnoni</span>
      <span class="text-sm text-text-muted">© {currentYear} All rights reserved.</span>
    </div>
    
    <div class="flex gap-4">
      <a href="https://github.com/placeholder" target="_blank" aria-label="GitHub" class="text-text-secondary hover:text-action-primary transition-colors active:scale-90">
        <Github class="w-5 h-5" />
      </a>
      <a href="https://linkedin.com/in/placeholder" target="_blank" aria-label="LinkedIn" class="text-text-secondary hover:text-action-primary transition-colors active:scale-90">
        <Linkedin class="w-5 h-5" />
      </a>
      <a href="mailto:contact@danielecompagnoni.dev" class="text-text-secondary hover:text-action-primary transition-colors active:scale-90" aria-label="Email">
        <Mail class="w-5 h-5" />
      </a>
    </div>
  </div>
</footer>
