---
import { Github, Linkedin, Mail, Phone } from 'lucide-vue-next';
import LionIcon from '@/components/ui/LionIcon.astro';
---

<footer class="mt-auto border-t border-border-subtle bg-bg-elevated py-12">
  <div class="max-w-[1200px] mx-auto px-4 sm:px-6 lg:px-8 flex flex-col md:flex-row justify-between items-center gap-6">
    
    <div class="flex items-center gap-2 group cursor-pointer">
      <div class="w-6 h-6 text-text-primary group-hover:text-action-primary transition-colors">
        <LionIcon />
      </div>
      <span class="font-sans font-semibold text-lg tracking-tight">DC.</span>
      <span class="text-sm font-mono text-text-muted border-l border-border-subtle pl-2">© {new Date().getFullYear()}</span>
    </div>

    <div class="flex items-center gap-6">
      <a href="mailto:danielecompagnoni.business@proton.me" class="text-text-secondary hover:text-action-primary transition-all duration-200 active:scale-90" aria-label="Email">
        <Mail class="w-5 h-5" />
      </a>
      <a href="tel:+393270593742" class="text-text-secondary hover:text-action-primary transition-all duration-200 active:scale-90" aria-label="Phone">
        <Phone class="w-5 h-5" />
      </a>
      <a href="https://github.com/daniele-compagnoni" target="_blank" class="text-text-secondary hover:text-action-primary transition-all duration-200 active:scale-90" aria-label="GitHub">
        <Github class="w-5 h-5" />
      </a>
      <a href="https://linkedin.com/in/daniele-compagnoni-5b3a502a6" target="_blank" class="text-text-secondary hover:text-action-primary transition-all duration-200 active:scale-90" aria-label="LinkedIn">
        <Linkedin class="w-5 h-5" />
      </a>
    </div>
    
  </div>
</footer>
